filters:
  or:
    - file.ext == "md"
    - file.ext == "mdx"
formulas:
  Slug: |-
    if(file.folder == "posts", "/posts/" + file.name.replace(".md", ""), 
      if(file.folder == "pages", "/" + file.name.replace(".md", ""), 
        if(file.folder == "special", if(file.name.replace(".md", "") == "home", "/", "/" + file.name.replace(".md", "")), 
          if(file.folder == "projects", "/projects/" + file.name.replace(".md", ""), 
            if(file.folder == "docs", "/docs/" + file.name.replace(".md", ""), 
              "/" + file.folder)))))
  Content Folder: |-
    if(file.name == "index",
      if(file.folder != "",
        if(file.folder.replace("/" + file.folder.replace(/.*\//, ""), "") != "",
          file.folder.replace("/" + file.folder.replace(/.*\//, ""), ""),
          file.folder
        ),
        "root"
      ),
      if(file.folder != "",
        file.folder,
        "root"
      )
    )
properties:
  file.fullname:
    displayName: Full File Name
  file.name:
    displayName: File Name
  formula.Slug:
    displayName: Path
  note.date:
    displayName: Date
  note.description:
    displayName: Description
  note.draft:
    displayName: Draft
  note.pubDate:
    displayName: Date
  note.title:
    displayName: Title
views:
  - type: cms
    name: Announcements
    filters:
      and:
        - file.folder.startsWith("Announcements")
    sort:
      - property: file.ctime
        direction: DESC
    imageFormat: cover
    showDate: true
    customizeNewButton: true
    newNoteLocation: Announcements
    fallbackToEmbeds: if-empty
    propertyDisplay1: file.fullname
    showTextPreview: true
    propertyLabels: above
    titleProperty: file.fullname
    titlePropertyNested: file.fullname
    dateProperty: file.ctime
    showTags: false
    showDraftStatus: false
  - type: cms
    name: Commands
    filters:
